# ============================================================
#  BrandAgent - Environment Variables
#  cp .env.local.example .env.local
# ============================================================

# -- REQUIRED -------------------------------------------------
GEMINI_API_KEY=AIza_YOUR_GEMINI_KEY_HERE

# -- CIRCLE NANOPAYMENTS (optional - sim mode without these) --
CIRCLE_API_KEY=TEST_API_KEY_YOUR_VALUE_HERE
CIRCLE_ENTITY_SECRET=YOUR_ENTITY_SECRET_HERE

# -- CIRCLE WALLET IDs (one per agent) -----------------------
CIRCLE_ORCHESTRATOR_WALLET_ID=
CIRCLE_CREATOR_WALLET_ID=
CIRCLE_WEBSITE_WALLET_ID=
CIRCLE_SOCIAL_WALLET_ID=
CIRCLE_VERIFIER_WALLET_ID=
CIRCLE_ANALYTICS_WALLET_ID=

# -- TINYFISH AGENT API --------------------------------------
TINYFISH_API_KEY=
TINYFISH_API_BASE_URL=https://agent.tinyfish.ai
TINYFISH_USE_VAULT=true
TINYFISH_VAULT_PROVIDER=
TINYFISH_VAULT_TOKEN=

# -- ARC L1 (defaults from CLAUDE.md - change only if Arc updates) --
ARC_CHAIN_ID=1234
ARC_EXPLORER_URL=https://explorer.arc.io

# -- IMAGE GENERATION ----------------------------------------
# Uses gemini-2.0-flash-preview-image-generation by default
# Set to "disabled" to always use SVG placeholder fallback
IMAGE_GENERATION_ENABLED=true

# -- APP ------------------------------------------------------
NODE_ENV=development
PORT=3000
